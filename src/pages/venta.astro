---
import '@styles/venta.scss';
import Layout from '@layouts/Layout.astro';

import SidebarMenu from "@components/Layout/SidebarMenu.astro";
import SidebarOptions from "@components/Layout/SidebarOptions.astro";
import Canvas from "@components/Layout/Canvas.astro";

---

<Layout title="Punto de Venta">
  <main class="Pos-Container">
    <section class="Pos-Header">
      <p class="user">Punto de Venta</p>
      <p class="Data-product">text center</p>
      <div class="Search-content">
        <input 
          type="text"
          id="searchLabel"
          class="searchBar"
        >
      </div>
    </section>
    <section class="Pos-Content">
      <SidebarMenu/>
      <Canvas/>
      <SidebarOptions/>
    </section>
  </main>
</Layout>

<script src="@components/scripts/venta.js"></script>